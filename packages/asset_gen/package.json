{
  "name": "@dumrunner/asset_gen",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prewarm": "tsx scripts/prewarm.ts",
    "smoke": "tsx scripts/smoke.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@dumrunner/shared": "*",
    "sharp": "^0.34.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1"
  }
}
