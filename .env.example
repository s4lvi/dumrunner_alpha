# Copy this file to .env.local at the repo root and fill in values.
# Both packages/client and packages/server read from this file (loaded by their dev scripts).

# --- Supabase ---
# Find these in your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Service-role key. SERVER-SIDE ONLY. Never expose to the browser.
# Used by the websocket game server (and Next.js server-only API routes) to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Game server ---
# Public WS URL the browser uses to connect. For local dev, ws://127.0.0.1:8070.
# (Using 127.0.0.1 instead of localhost avoids IPv4/IPv6 ambiguity on macOS.)
NEXT_PUBLIC_GAME_SERVER_WS_URL=ws://127.0.0.1:8070

# Port the websocket server listens on.
GAME_SERVER_PORT=8070

# Bind interface for the websocket server. 127.0.0.1 in dev (no LAN exposure);
# 0.0.0.0 in containers / Fly so the platform's proxy can reach the process.
GAME_SERVER_HOST=127.0.0.1

# Shared HMAC secret for signing the short-lived join tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JOIN_TOKEN_SECRET=replace_me_with_a_long_random_hex_string

# --- Asset gen (optional) ---
# URL of the asset_gen service. Browser fetches /v1/assets/index from here at
# boot to build a kind→texture map. If unset, the game falls back to
# procedural shapes (no AI assets). Local dev: http://localhost:8787.
NEXT_PUBLIC_ASSET_GEN_URL=http://localhost:8787

# Server-side mirror of the same URL. Game server uses this at boot to
# fire a prewarm bundle (every enemy template, building kind, material,
# projectile) so anything new gets queued for generation. Cache keys
# dedup, so a warm asset_gen is an instant no-op.
ASSET_GEN_URL=http://localhost:8787

# Bearer token for asset_gen if it has ASSET_GEN_SERVICE_TOKEN set.
# Match the value used by the asset_gen process. Optional.
# ASSET_GEN_SERVICE_TOKEN=local-dev-token

# --- Discord (optional) ---
# Used for the "Continue with Discord" button on /login and (later) the
# Activity SDK in-call flow. Both flows use the same Discord application.
# Create at https://discord.com/developers/applications, then in
# OAuth2 → Redirects add: <site origin>/api/auth/discord/callback
NEXT_PUBLIC_DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Full callback URL the route handler builds Discord OAuth requests with.
# Must exactly match the redirect registered in the Developer Portal.
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback
