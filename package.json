{
  "name": "dumrunner",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "dotenv -e .env.local -- npm-run-all --parallel dev:client dev:server",
    "dev:asset_gen": "dotenv -e .env.local -- npm --workspace @dumrunner/asset_gen run dev",
    "dev:client": "npm --workspace @dumrunner/client run dev",
    "dev:server": "npm --workspace @dumrunner/server run dev",
    "build": "npm-run-all --serial build:shared build:asset_gen build:client build:server",
    "build:shared": "npm --workspace @dumrunner/shared run build",
    "build:asset_gen": "npm --workspace @dumrunner/asset_gen run build",
    "build:client": "dotenv -e .env.local -- npm --workspace @dumrunner/client run build",
    "build:server": "npm --workspace @dumrunner/server run build",
    "typecheck": "npm-run-all --serial typecheck:shared typecheck:asset_gen typecheck:client typecheck:server",
    "typecheck:shared": "npm --workspace @dumrunner/shared run typecheck",
    "typecheck:asset_gen": "npm --workspace @dumrunner/asset_gen run typecheck",
    "typecheck:client": "npm --workspace @dumrunner/client run typecheck",
    "typecheck:server": "npm --workspace @dumrunner/server run typecheck"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3"
  }
}
