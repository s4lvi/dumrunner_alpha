# Files excluded from the Docker build context. Keeps the image small and
# avoids invalidating layer caches on irrelevant changes.

# Node + build outputs
node_modules
**/node_modules
dist
**/dist
.next
**/.next
out
**/out
*.tsbuildinfo

# Env files — secrets come from Fly, not the image
.env
.env.*
!.env.example

# Git + IDE + OS
.git
.gitignore
.idea
.vscode
.DS_Store

# Client workspace — not deployed to Fly. Keep package.json so npm
# workspace resolution succeeds during the install step.
packages/client
!packages/client/package.json

# Repo docs / planning that don't ship in the image
GDD.md
README.md
*.md
# asset_gen is now a workspace dep of the server (request builders).
# Keep package.json + src; drop the heavy non-runtime extras
# (DESIGN.md, scripts, generated assets, the viewer) so the image
# stays lean.
packages/asset_gen/.asset_gen
packages/asset_gen/scripts
packages/asset_gen/public
packages/asset_gen/DESIGN.md
packages/asset_gen/README.md
supabase

# Claude / agent metadata
.claude
